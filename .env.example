# Railway injects DATABASE_URL automatically when you attach a Postgres plugin.
# For local development, point this at your own Postgres instance.
DATABASE_URL=postgres://user:password@localhost:5432/cake_recipes

# Set to "true" only if your Postgres connection requires SSL (e.g. some
# external/public Railway proxy URLs). Leave "false" for Railway's internal URL.
PGSSL=false

# Any long random string — used to sign login sessions.
JWT_SECRET=change-this-to-a-long-random-string

# Railway sets PORT automatically; only needed for local dev.
PORT=3000

NODE_ENV=production

# Public URL of your deployed app (no trailing slash), used to build
# verification links and the Google OAuth redirect URI.
# e.g. https://cake-recipe-book-production.up.railway.app
APP_URL=

# Resend (https://resend.com) — used to send the "verify your email" message.
# Get an API key from the Resend dashboard after signing up (free tier is fine).
RESEND_API_KEY=
# "onboarding@resend.dev" works out of the box without verifying your own domain.
EMAIL_FROM=onboarding@resend.dev

# Google OAuth — from Google Cloud Console > APIs & Services > Credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
